DASHSCOPE_API_KEY=your-dashscope-api-key

SPRING_SERVER_PORT=9900

# 使用宝塔服务器上已有的 Redis 时，填写 Redis 对外可达地址。
# 如果 Redis 就在同一台机器上，优先填写服务器内网 IP，而不是 localhost。
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# 后端当前启动时仍依赖一个可访问的 Milvus 实例。
# 这里填写外部 Milvus 地址；若暂时放在你本机，需要先打通服务器到本机的网络。
MILVUS_HOST=your-milvus-host
MILVUS_PORT=19530
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_DATABASE=default

PROMETHEUS_URL=http://127.0.0.1:9090
PROMETHEUS_MOCK_ENABLED=true
CLS_MOCK_ENABLED=true
